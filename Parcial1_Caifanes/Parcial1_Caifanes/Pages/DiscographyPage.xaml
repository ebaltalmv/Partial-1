<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Parcial1_Caifanes.Models"
             x:Class="Parcial1_Caifanes.Pages.DiscographyPage"
             Title="DiscographyPage">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0"
                             EndPoint="1,1">
            <GradientStop Color="{DynamicResource BackgroundPage1}"
                          Offset="0.1" />
            <GradientStop Color="{DynamicResource BackgroundPage2}"
                          Offset="0.6" />
            <GradientStop Color="{DynamicResource BackgroundPage3}"
                          Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid Padding="10">
        <CollectionView x:Name="AlbumsCollection"
                        SelectionMode="Single"
                        SelectionChanged="OnAlbumSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,10"
                            Padding="10">
                        <HorizontalStackLayout Spacing="15">
                            <Image Source="{Binding ImageUrl}"
                                   WidthRequest="80"
                                   HeightRequest="80"
                                   Aspect="AspectFill" />
                            <VerticalStackLayout VerticalOptions="Center">
                                <Label Text="{Binding Name}"
                                       Style="{StaticResource TitleDiscPage}" />
                                <Label Text="{Binding Year}"
                                       Style="{StaticResource ContentDiscPage}" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>