<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Parcial1_Caifanes.Pages.DatailAlbumPage"
             x:Name="DetailPage"
             Title="DatailAlbumPage">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0"
                             EndPoint="1,1">
            <GradientStop Color="{DynamicResource BackgroundPage3}"
                          Offset="0.1" />
            <GradientStop Color="{DynamicResource BackgroundPage2}"
                          Offset="0.6" />
            <GradientStop Color="{DynamicResource BackgroundPage1}"
                          Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="20"
                             Spacing="20">

            <Image Source="{Binding ImageUrl}"
                   HeightRequest="300"
                   Aspect="AspectFit" />

            <Label Text="{Binding Name}"
                   Style="{DynamicResource TitleLabelStyle}" />

            <Label Text="{Binding Year}"
                   Style="{StaticResource TitleDiscPage}"
                   HorizontalOptions="Center" />

            <BoxView HeightRequest="1"
                     Color="{DynamicResource BoxView}"
                     Margin="0,10" />

            <Label Text="Sobre este álbum:"
                   Style="{StaticResource InfoAlbum}" />

            <Label Text="{Binding Description}"
                   Style="{StaticResource ContentBiography}" />

            <BoxView HeightRequest="1"
                     Color="{DynamicResource BoxView}"
                     Margin="0,10" />

            <Label Text="Lista de Canciones:"
                   Style="{StaticResource InfoAlbum}" />
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Songs}"
                                 Spacing="8"
                                 Margin="10,0,0,0">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="10"
                               CornerRadius="8"
                               HasShadow="True"
                               BorderColor="{DynamicResource BoxView}"
                               BackgroundColor="Transparent">

                            <HorizontalStackLayout Spacing="15"
                                                   VerticalOptions="Center">

                                <Image Source="{Binding BindingContext.ImageUrl, Source={x:Reference DetailPage}}"
                                       WidthRequest="40"
                                       HeightRequest="40"
                                       Aspect="AspectFill" />

                                <Label Text="{Binding .}"
                                       Style="{StaticResource ContentBiography}" />

                            </HorizontalStackLayout>

                        </Frame>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>